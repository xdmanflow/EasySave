<Window x:Class="EasySave.GUI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="700" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Log Format" FontWeight="Bold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="JSON" IsChecked="{Binding IsJson}" Margin="0,0,20,0"/>
                <RadioButton Content="XML"  IsChecked="{Binding IsXml}"/>
            </StackPanel>

            <TextBlock Text="Language" FontWeight="Bold" Margin="0,0,0,6"/>
            <ComboBox SelectedValue="{Binding Language}"
                      SelectedValuePath="Tag" Margin="0,0,0,16">
                <ComboBoxItem Content="English" Tag="en"/>
                <ComboBoxItem Content="French"  Tag="fr"/>
                <ComboBoxItem Content="Spanish" Tag="es"/>
            </ComboBox>

            <TextBlock Text="CryptoSoft Path" FontWeight="Bold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="..." Width="34"
                        Click="BrowseCrypto_Click" Margin="6,0,0,0"/>
                <TextBox Text="{Binding CryptoSoftPath, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <TextBlock Text="Business Software (backup pauses when detected)"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Add"
                        Command="{Binding AddBusinessCommand}" Width="50" Margin="6,0,0,0"/>
                <TextBox Text="{Binding NewBusiness, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. calc.exe"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Remove"
                        Command="{Binding RemoveBusinessCommand}"
                        Width="60" Margin="6,0,0,0" VerticalAlignment="Top"/>
                <ListBox ItemsSource="{Binding BusinessSoftwareList}"
                         SelectedItem="{Binding SelectedBusiness}" Height="80"/>
            </DockPanel>

            <TextBlock Text="Extensions to encrypt (.txt, .docx, ...)"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Add"
                        Command="{Binding AddExtensionCommand}" Width="50" Margin="6,0,0,0"/>
                <TextBox Text="{Binding NewExtension, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. .txt"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Remove"
                        Command="{Binding RemoveExtensionCommand}"
                        Width="60" Margin="6,0,0,0" VerticalAlignment="Top"/>
                <ListBox ItemsSource="{Binding EncryptedExtensions}"
                         SelectedItem="{Binding SelectedExtension}" Height="80"/>
            </DockPanel>

            <TextBlock Text="Priority Extensions (copied before others)"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Add"
                        Command="{Binding AddPriorityExtensionCommand}" Width="50" Margin="6,0,0,0"/>
                <TextBox Text="{Binding NewPriorityExtension, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. .pdf"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Remove"
                        Command="{Binding RemovePriorityExtensionCommand}"
                        Width="60" Margin="6,0,0,0" VerticalAlignment="Top"/>
                <ListBox ItemsSource="{Binding PriorityExtensions}"
                         SelectedItem="{Binding SelectedPriorityExtension}" Height="80"/>
            </DockPanel>

            <TextBlock Text="Max Parallel File Size (KB) - 0 means unlimited"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding MaxFileSizeKB, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16"/>

            <TextBlock Text="Log Centralization (Docker)"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Content="Local only"  IsChecked="{Binding IsLocal}" Margin="0,0,16,0"/>
                <RadioButton Content="Remote only" IsChecked="{Binding IsRemote}" Margin="0,0,16,0"/>
                <RadioButton Content="Both"        IsChecked="{Binding IsBoth}"/>
            </StackPanel>
            <TextBlock Text="Docker Server URL" Margin="0,0,0,4"/>
            <TextBox Text="{Binding DockerLogUrl, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20" ToolTip="e.g. http://localhost:5050/log"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save"   Click="Save_Click"   Width="80" Margin="0,0,10,0"/>
                <Button Content="Cancel" Click="Cancel_Click" Width="80"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>