<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasySave v3.0 - ProSoft" Height="660" Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#4C1D95"/>
                                <Setter Property="Foreground" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#059669"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WarningBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#D97706"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B45309"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BlackBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#111111"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A2E"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4C1D95"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#000000" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="EasySave" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#312E81" CornerRadius="4"
                            Padding="8,2" Margin="10,0,0,0">
                        <TextBlock Text="v3.0" FontSize="11"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <Image Grid.Column="1" Source="images/Logo prosoft.png" Height="55"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#111111" CornerRadius="10"
                    Padding="20,16" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock x:Name="TxtTotalJobs" Text="Total Jobs"
                               Foreground="#555555" FontSize="12"/>
                    <TextBlock Text="{Binding Jobs.Count}" Foreground="White"
                               FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#111111" CornerRadius="10"
                    Padding="20,16" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock x:Name="TxtStatus" Text="Status"
                               Foreground="#555555" FontSize="12"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#A78BFA"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#111111" CornerRadius="10"
                    Padding="20,16" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="TxtQuickActions" Text="Quick Actions"
                               Foreground="#555555" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnRunAll" Content="Run All"
                                Style="{StaticResource GreenBtn}"
                                Command="{Binding RunAllJobsCommand}"
                                Padding="12,6" FontSize="12"/>
                        <Button x:Name="BtnSettings" Content="Settings"
                                Style="{StaticResource BlackBtn}"
                                Command="{Binding OpenSettingsCommand}"
                                Padding="12,6" FontSize="12" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#111111" CornerRadius="10"
                Margin="24,16,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="16,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtBackupJobs" Text="Backup Jobs"
                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnAdd" Content="+ Add"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding AddJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                        <Button x:Name="BtnEdit" Content="Edit"
                                Style="{StaticResource BlackBtn}"
                                Command="{Binding EditJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                        <Button x:Name="BtnDelete" Content="Delete"
                                Style="{StaticResource DangerBtn}"
                                Command="{Binding DeleteJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,16,0"/>
                        <Button x:Name="BtnRun" Content="Run"
                                Style="{StaticResource GreenBtn}"
                                Command="{Binding RunJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                        <Button Content="Pause"
                                Style="{StaticResource WarningBtn}"
                                Command="{Binding PauseJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                        <Button Content="Resume"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ResumeJobCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                        <Button Content="Stop"
                                Style="{StaticResource DangerBtn}"
                                Command="{Binding StopJobCommand}"
                                Padding="12,6" FontSize="12"/>
                    </StackPanel>
                </Grid>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Jobs}"
                          SelectedItem="{Binding SelectedJob}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="#111111"
                          RowHeight="42"
                          FontSize="13">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#0D0D0D"/>
                            <Setter Property="Foreground" Value="#555555"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColName" Header="JOB NAME"
                                            Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="STATE"
                                            Binding="{Binding State}" Width="80"/>
                        <DataGridTemplateColumn Header="PROGRESS" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,0">
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}"
                                                     Height="16" Background="#222" Foreground="#059669" BorderThickness="0"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0.0}%}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="ColSource" Header="SOURCE"
                                            Binding="{Binding SourceDirectory}" Width="*"/>
                        <DataGridTextColumn x:Name="ColTarget" Header="TARGET"
                                            Binding="{Binding TargetDirectory}" Width="*"/>
                        <DataGridTextColumn x:Name="ColType" Header="TYPE"
                                            Binding="{Binding Type}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#000000" Padding="24,0">
            <TextBlock Text="ProSoft 2026 - EasySave v3.0"
                       Foreground="#333333" FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>